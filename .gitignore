# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Archivos excluidos del control de versiones
# ─────────────────────────────────────────────────────────────────────────────

# Entorno virtual Python
.venv/
venv/
env/
ENV/

# Caché de bytecode Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Pytest — caché y reportes
.pytest_cache/
.coverage
htmlcov/
*.xml

# IDEs y editores
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Variables de entorno (¡NUNCA versionar credenciales!)
.env
.env.local
.env.*.local

# Distribución y build
dist/
build/
*.egg-info/
*.egg

# Logs
*.log
logs/

# Jupyter Notebooks (checkpoints)
.ipynb_checkpoints/
