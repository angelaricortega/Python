# ════════════════════════════════════════════════════════════════════════════════
# .env.example — Variables de Entorno para RiskAPI
# ════════════════════════════════════════════════════════════════════════════════
#
# SEMANA 6 — Inyección de Dependencias con pydantic-settings:
#   Este archivo .env es cargado automáticamente por la clase Settings()
#   en config.py usando pydantic-settings BaseSettings.
#
# INSTRUCCIONES:
#   1. Copie este archivo a .env (sin el .example)
#      cp .env.example .env  (Linux/Mac)
#      copy .env.example .env  (Windows)
#   2. Ajuste los valores según su entorno
#   3. El archivo .env NO se sube a Git (está en .gitignore)
#
# ════════════════════════════════════════════════════════════════════════════════

# ── Servidor ────────────────────────────────────────────────────────────────────
# Host y puerto donde se ejecutará la API
HOST=127.0.0.1
PORT=8000

# Nivel de log: debug, info, warning, error, critical
LOG_LEVEL=info

# Entorno: development, production
ENVIRONMENT=development

# ── API de Datos Abiertos ───────────────────────────────────────────────────────
# Endpoint Socrata de Datos Abiertos Colombia
API_BASE=https://www.datos.gov.co/resource/3kqn-n4za.json

# Timeout para peticiones HTTP (segundos)
HTTP_TIMEOUT=15

# Límite de registros a descargar (1-10000)
DEFAULT_LIMIT=500

# ── Configuración de la API ────────────────────────────────────────────────────
# Título y descripción que aparecen en Swagger UI
API_TITLE=API de Análisis de Riesgo Crediticio
API_VERSION=1.0.0
API_DESCRIPTION=Sistema Financiero Colombiano — Datos Abiertos Gov.co

# ── CORS ────────────────────────────────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
# En producción, restringir a dominios específicos
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Base de Datos (Futuro — SQLAlchemy) ────────────────────────────────────────
# Actualmente se usa memoria, pero para producción:
# DATABASE_URL=sqlite:///riesgo_crediticio.db
# DATABASE_URL=postgresql://user:password@localhost:5432/riesgo_db

# ── Archivos ────────────────────────────────────────────────────────────────────
# Directorio para archivos subidos (CSV, Excel)
UPLOAD_DIR=uploads

# Directorio para archivos generados (gráficas, resultados)
OUTPUT_DIR=outputs

# ════════════════════════════════════════════════════════════════════════════════
# NOTAS:
#   - Este archivo es un EJEMPLO. Cree .env con sus propios valores.
#   - NUNCA suba .env con contraseñas reales a Git.
#   - pydantic-settings valida automáticamente los tipos (int, str, bool).
#   - Las variables son case-insensitive (HOST = host = Host).
# ════════════════════════════════════════════════════════════════════════════════
