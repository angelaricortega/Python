# ════════════════════════════════════════════════════════════════════════════════
# .gitignore — Sistema de Análisis de Riesgo Crediticio
# Sistema Financiero Colombiano — Datos Abiertos Gov.co
# ════════════════════════════════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Spyder projects
.spyderproject
.spyproject

# Rope projects
.ropeproject

# Wax plugins
wxTools

# Virtualenvwrapper
env/
venv/
ENV/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ── Proyecto específico ─────────────────────────────────────────────────────────
# Outputs (generados por el pipeline)
outputs/*.png
outputs/*.json
outputs/*.pkl
outputs/*.csv

# Keep .gitignore in outputs folder
!outputs/.gitignore

# Logs
*.log

# Database files (si se usa SQLite en el futuro)
*.db
*.sqlite
*.sqlite3

# API Keys y secretos (NUNCA subir estos archivos)
.env
.env.local
.env.production
*.key
*.pem
credentials.json
service_account.json

# ── Documentación ───────────────────────────────────────────────────────────────
# Mantener README y notebooks, pero ignorar checkpoints
.DS_Store
Thumbs.db

# ════════════════════════════════════════════════════════════════════════════════
# Notas:
#   - Los notebooks .ipynb SÍ se versionan (contienen documentación ejecutable)
#   - Los outputs SÍ se versionan para demo, pero se pueden ignorar si son grandes
#   - NUNCA subir .env con API keys o credenciales
